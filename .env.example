# Turso database (libSQL - sqlite-compatible cloud DB)
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Secret used to sign approval magic-link tokens and admin session cookies.
# Generate with: openssl rand -base64 32
APP_SECRET=replace-with-random-32-byte-base64-string

# Shared password for admins to log into the app
# Generate the hash with: node scripts/hash-password.js "YourPasswordHere"
ADMIN_PASSWORD_HASH=$2a$10$replaceWithBcryptHashOfYourAdminPassword

# Resend API key (https://resend.com)
RESEND_API_KEY=re_yourkey

# Where approval emails should be sent. Single address OR comma-separated
# list of addresses — the email goes to all of them and the first click wins.
# Examples:
#   APPROVER_EMAIL=boss@fatty-chem.com
#   APPROVER_EMAIL=boss@fatty-chem.com,ops-lead@fatty-chem.com,plant-mgr@fatty-chem.com
APPROVER_EMAIL=approver@fatty-chem.com

# "From" address - must be on a domain you've verified in Resend.
# For testing, use "onboarding@resend.dev"
EMAIL_FROM=daysoff@fatty-chem.com

# Public URL of this app (used in approval links). Set to your Vercel URL.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Secret for the daily auto-approve cron (must match vercel cron header)
CRON_SECRET=another-random-string
